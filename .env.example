# =============================================================================
# Copy to `.env` at the repository root and fill in values. Do not commit `.env`.
#
# - Docker: `docker/docker-compose*.yml` uses `env_file: ../.env` and expands
#   `${VAR}` into the container's environment, where the FastAPI process reads
#   it via `os.environ`. This is the primary consumer of this file.
# - Cron entrypoint: `docker-entrypoint.sh` sources this file directly.
# - Bare-metal uvicorn does NOT auto-load this file. For self-hosting without
#   Docker, put Web API / Admin Console values in `config.py` (see
#   `config.py.example` § "API CONSOLE / BACKEND SERVICE"), or `export VAR=...`
#   in your shell before launching uvicorn. Environment variables override
#   `config.py` values (see `apps/api/infra/auth.py::_resolve`).
# =============================================================================

# =============================================================================
# WEB API / ADMIN CONSOLE (Docker / shell-export only — bare uvicorn reads config.py)
# =============================================================================

# JWT signing secret (required in production, e.g. openssl rand -base64 48)
API_SECRET_KEY=

# Web console admin (use either plain password OR precomputed bcrypt hash)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
# ADMIN_PASSWORD_HASH=

# Optional read-only user
# READONLY_USERNAME=readonly
# READONLY_PASSWORD=

# Sensitive config encryption (Fernet key, optional):
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# SECRETS_ENCRYPTION_KEY=

# =============================================================================
# DOCKER / CRON (container env_file)
# =============================================================================
# Cron format: minute hour day month weekday
# Example: "0 2 * * *" means run at 2:00 AM every day

# Main Spider - Daily scraping job
# Default: Run at 3:00 AM every day
CRON_SPIDER=0 3 * * *
SPIDER_COMMAND=cd /app && /usr/local/bin/python scripts/spider --use-proxy >> /var/log/cron.log 2>&1

# Pipeline Run and Notify - Process downloaded content
# Default: Run at 4:00 AM every day (after spider completes)
CRON_PIPELINE=0 4 * * *
PIPELINE_COMMAND=cd /app && /usr/local/bin/python pipeline.py >> /var/log/cron.log 2>&1

# qBittorrent Uploader - Upload torrents to qBittorrent
# Default: Run at 3:30 AM every day
CRON_QBTORRENT=30 3 * * *
QBTORRENT_COMMAND=cd /app && /usr/local/bin/python scripts/qb_uploader.py >> /var/log/cron.log 2>&1

# PikPak Bridge - Sync with PikPak cloud storage
# Default: Run at 5:00 AM every day
CRON_PIKPAK=0 5 * * *
PIKPAK_COMMAND=cd /app && /usr/local/bin/python scripts/pikpak_bridge.py >> /var/log/cron.log 2>&1

# OPTIONAL: Additional Cron Jobs
# You can add more cron jobs by uncommenting and configuring below

# Weekly cleanup job (example)
# CRON_CLEANUP=0 1 * * 0
# CLEANUP_COMMAND=cd /app && /usr/local/bin/python cleanup_script.py >> /var/log/cron.log 2>&1

# Hourly monitoring job (example)
# CRON_MONITOR=0 * * * *
# MONITOR_COMMAND=cd /app && /usr/local/bin/python monitor.py >> /var/log/cron.log 2>&1

# ENABLE/DISABLE INDIVIDUAL JOBS — 'true' / 'false'; if unset, defaults to enabled
ENABLE_SPIDER=true
ENABLE_PIPELINE=true
ENABLE_QBTORRENT=true
ENABLE_PIKPAK=true

# TIMEZONE (optional; compose may also set TZ)
# TZ=Asia/Shanghai
# TZ=America/New_York
# TZ=Europe/London

# LOGGING (optional)
# MAX_LOG_SIZE=100M
# MAX_LOG_FILES=10

# CRON EXAMPLES
# Every minute:        * * * * *
# Every 5 minutes:     */5 * * * *
# Every hour:          0 * * * *
# Every day at 2 AM:   0 2 * * *
# Every week (Sunday): 0 0 * * 0
# Every month:         0 0 1 * *
# Twice a day:         0 2,14 * * *
