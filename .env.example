# Copy to .env and fill in values. api/server.py loads this from the project root on startup.
# Do not commit a real .env to Git.

# JWT signing secret (e.g. openssl rand -base64 48)
API_SECRET_KEY=

# Web console admin (use either plain password OR precomputed bcrypt hash)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
# ADMIN_PASSWORD_HASH=

# Optional read-only user
# READONLY_USERNAME=readonly
# READONLY_PASSWORD=

# Sensitive config encryption (Fernet key, optional):
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# SECRETS_ENCRYPTION_KEY=
